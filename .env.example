# -----------------------------------------------------------------------------
# Snowflake / dbt — copy this file to `.env` and replace placeholder values.
# `.env` is gitignored; do not commit real credentials.
#
# Resolved by profiles.yml (`dbt_snowflake.dev`) via `{{ env_var('...') }}`.
# Snapshots (`snapshots/*.yml`) require `DBT_SNOWFLAKE_DATABASE` with no fallback.
# -----------------------------------------------------------------------------
DBT_SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_IDENTIFIER
DBT_SNOWFLAKE_USER=YOUR_SNOWFLAKE_USER
DBT_SNOWFLAKE_PASSWORD=YOUR_PASSWORD
DBT_SNOWFLAKE_ROLE=YOUR_ROLE
DBT_SNOWFLAKE_DATABASE=YOUR_DATABASE
DBT_SNOWFLAKE_WAREHOUSE=YOUR_WAREHOUSE
DBT_SNOWFLAKE_SCHEMA=YOUR_DEFAULT_SCHEMA
